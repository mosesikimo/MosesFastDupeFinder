<Window x:Class="FastDupeFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FastDupeFinder"
        Title="{local:Loc WindowTitle, '渡川 Moses - 快速重複影片檢索工具'}" Height="700" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- 左側：控制面板與檔案列表 -->
        <DockPanel Grid.Column="0" Margin="10">
            
            <!-- 上方控制面板 -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                
                <!-- 掃描條件設定 -->
                <GroupBox Header="{local:Loc ConfigHeader, '掃描條件設定'}" Padding="5" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 第一行：目標路徑與進階篩選 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{local:Loc LblPath, '目標路徑:'}" VerticalAlignment="Center" Margin="0,0,5,5"/>
                        <TextBox x:Name="PathTextBox" Grid.Row="0" Grid.Column="1" Text="D:\; E:\" ToolTip="{local:Loc TipPath, '可輸入多個路徑，以分號 (;) 隔開'}" VerticalAlignment="Center" Margin="0,0,5,5"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="{local:Loc BtnAdd, '加入...'}" Width="50" Margin="0,0,5,5" Click="BrowseFolder_Click"/>
                        <Button Grid.Row="0" Grid.Column="3" Content="{local:Loc BtnClear, '清除'}" Width="40" Margin="0,0,15,5" Click="ClearPath_Click"/>
                        
                        <CheckBox x:Name="SubDirCheckBox" Grid.Row="0" Grid.Column="4" Content="{local:Loc ChkSubDir, '包含子目錄'}" IsChecked="True" VerticalAlignment="Center" Margin="0,0,15,5"/>
                        
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="{local:Loc LblMinSize, '最小檔案 (MB):'}" VerticalAlignment="Center" Margin="0,0,5,5"/>
                        <TextBox x:Name="MinSizeTextBox" Grid.Row="0" Grid.Column="6" Text="100" Width="40" VerticalAlignment="Center" Margin="0,0,15,5"/>
                        
                        <TextBlock Grid.Row="0" Grid.Column="7" Text="{local:Loc LblMinLen, '最短長度 (分):'}" VerticalAlignment="Center" Margin="0,0,5,5"/>
                        <TextBox x:Name="MinLengthTextBox" Grid.Row="0" Grid.Column="8" Text="5" Width="30" VerticalAlignment="Center" Margin="0,0,5,5"/>

                        <!-- 第二行：排除目錄設定 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{local:Loc LblExclude, '排除目錄:'}" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="DarkRed"/>
                        <TextBox x:Name="ExcludePathTextBox" Grid.Row="1" Grid.Column="1" ToolTip="{local:Loc TipExclude, '不想掃描的路徑 (如: C:\Windows; D:\Temp)'}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <Button Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Content="{local:Loc BtnAddExclude, '加入排除'}" Width="65" HorizontalAlignment="Left" Margin="0,0,15,0" Click="BrowseExcludeFolder_Click"/>
                    </Grid>
                </GroupBox>

                <!-- 操作按鈕列 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="ScanBtn" Content="{local:Loc BtnScan, '🔍 開始掃描'}" Width="100" Height="30" Margin="0,0,15,0" Click="ScanButton_Click" Background="#FFFFEBF2" ToolTip="{local:Loc TipScan, '全員互相比對頭尾特徵，尋找100%相同的重複檔案'}"/>
                                               
                        <!-- 🌟 語言切換按鈕 -->
                        <Button x:Name="ToggleLangBtn" Content="{local:Loc BtnToggleLang, '🌐 English'}" Width="95" Height="30" Margin="0,0,10,0" Click="ToggleLangBtn_Click" Background="#FFF5EE" ToolTip="{local:Loc TipToggleLang, '切換介面語言 / Change Language'}"/>
                        
                        <!-- 🌟 關於作者按鈕 -->
                        <Button Content="{local:Loc BtnAbout, 'ℹ️ 關於作者'}" Width="95" Height="30" Margin="0,0,10,0" Click="AboutButton_Click" Background="#FFF0F8FF" ToolTip="{local:Loc TipAbout, '查看軟體介紹與作者資訊'}"/>
                    </StackPanel>
                    
                    <!-- 狀態列文字 -->
                    <TextBlock x:Name="StatusText" Grid.Column="1" VerticalAlignment="Center" Foreground="DimGray" Margin="5,0,0,0"/>
                    
                    <!-- 刪除按鈕放最右邊 (加入 x:Name 供鎖定) -->
                    <Button x:Name="DeleteBtn" Grid.Column="2" Content="{local:Loc BtnDeleteSelected, '🗑️ 刪除選取檔案'}" Width="100" Height="30" Background="#FFFFE6E6" Foreground="DarkRed" Click="DeleteSelected_Click"/>
                </Grid>
            </StackPanel>

            <!-- 檔案列表 -->
            <ListView x:Name="FileListView" SelectionChanged="FileListView_SelectionChanged" SelectionMode="Extended" KeyDown="FileListView_KeyDown" MouseDoubleClick="FileListView_MouseDoubleClick">
                
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{local:Loc MenuOpenDir, '📂 開啟檔案所在目錄'}" Click="OpenDirectory_Click"/>
                    </ContextMenu>
                </ListView.ContextMenu>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="{Binding RowBackgroundColor}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#CCE8FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{local:Loc ColSim, '相似度'}" DisplayMemberBinding="{Binding SimilarityStr}" Width="150"/>
                        <GridViewColumn Header="{local:Loc ColSize, '檔案大小'}" DisplayMemberBinding="{Binding SizeStr}" Width="80"/>
                        <GridViewColumn Header="{local:Loc ColDuration, '時間長度'}" DisplayMemberBinding="{Binding DurationStr}" Width="80"/>
                        <GridViewColumn Header="{local:Loc ColBitrate, '位元率(Kbps)'}" DisplayMemberBinding="{Binding BitrateKbpsStr}" Width="85"/>
                        <GridViewColumn Header="{local:Loc ColRes, '解析度'}" DisplayMemberBinding="{Binding Resolution}" Width="90"/>
                        <GridViewColumn Header="{local:Loc ColPath, '檔案路徑'}" DisplayMemberBinding="{Binding FilePath}" Width="800"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>

        <!-- 分隔線 -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

        <!-- 右側：檔案預覽區 -->
        <Border Grid.Column="2" Margin="10" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <TextBlock x:Name="PreviewHintText" Text="{local:Loc TxtNoFile, '尚未選擇檔案'}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
                <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed"/>
                <MediaElement x:Name="PreviewVideo" LoadedBehavior="Manual" UnloadedBehavior="Close" Stretch="Uniform" ScrubbingEnabled="True" Visibility="Collapsed" Volume="0"/>
                <TextBox x:Name="PreviewText" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Visibility="Collapsed" BorderThickness="0" Margin="5"/>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10">
                    <Button x:Name="UpgradeBtn" Content="{local:Loc BtnUpgrade, '✨ 升級格式'}" Margin="0,0,10,0" Padding="10,5" Click="UpgradeBtn_Click" Visibility="Collapsed" Background="#FFFFF0DF" Foreground="#FFD84315" ToolTip="{local:Loc TipUpgrade, '自動轉換老舊格式，優先使用極速換殼，失敗則重新編碼'}"/>
                    <Button x:Name="RepairBtn" Content="{local:Loc BtnRepair, '🛠️ 斷尾修復'}" Margin="0,0,10,0" Padding="10,5" Click="RepairBtn_Click" Visibility="Collapsed" Background="#FFFFE6E6" Foreground="DarkRed" ToolTip="{local:Loc TipRepair, '嘗試切除損壞的尾部並修復此檔案 (容許損失 &lt; 5%)'}"/>
                    <Button x:Name="OpenBtn" Content="{local:Loc BtnOpen, '開啟檔案'}" Padding="10,5" Click="OpenBtn_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>